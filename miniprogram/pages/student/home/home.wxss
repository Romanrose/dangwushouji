.student-head {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.student-title {
  font-weight: 700;
  margin-bottom: 12rpx;
}

.student-line {
  color: #475569;
  margin-top: 10rpx;
  line-height: 1.5;
}

.form-note {
  margin-bottom: 20rpx;
  line-height: 1.5;
}

button {
  margin-top: 20rpx;
}

.field-grid {
  display: flex;
  gap: 16rpx;
}

.half {
  flex: 1;
}

.dependent-field {
  padding: 18rpx;
  border-radius: 10rpx;
  background: #f0fdfa;
  border: 1rpx solid #99f6e4;
}

.save-message {
  margin: 20rpx 0 0;
  padding: 18rpx;
  border-radius: 10rpx;
  color: #334155;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.scan-section {
  margin-top: 28rpx;
}

.scan-field {
  margin-top: 20rpx;
}

.scan-actions {
  display: flex;
  gap: 16rpx;
}

.scan-actions button {
  flex: 1;
}
