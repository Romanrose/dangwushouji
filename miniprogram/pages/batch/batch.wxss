.mode-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 12rpx;
  background: #ffffff;
}

.mode {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 8rpx;
  color: #475569;
  text-align: center;
  font-weight: 700;
}

.mode.active {
  color: #ffffff;
  background: #0f766e;
}

.field-grid {
  display: flex;
  gap: 16rpx;
}

.half {
  flex: 1;
}

.dependent-field,
.notice {
  padding: 18rpx;
  border-radius: 10rpx;
  background: #f0fdfa;
  border: 1rpx solid #99f6e4;
}

.notice {
  margin-bottom: 20rpx;
  color: #0f766e;
  font-size: 24rpx;
  line-height: 1.5;
}

.names-box,
.ids-box {
  min-height: 260rpx;
}

.result-message {
  margin: 20rpx 0;
  padding: 18rpx;
  border-radius: 10rpx;
  color: #334155;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.danger {
  background: #b91c1c;
  color: #ffffff;
}
