.demo-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #ecfeff;
  border: 1rpx solid #99f6e4;
}

.demo-title {
  color: #0f766e;
  font-weight: 800;
}

.demo-sub {
  margin-top: 4rpx;
  color: #475569;
  font-size: 24rpx;
}

.demo-actions {
  display: flex;
  gap: 12rpx;
}

.demo-link {
  min-width: 72rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #0f766e;
  font-size: 24rpx;
  text-align: center;
}

.muted-link {
  background: #64748b;
}

.ledger-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.search {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 10rpx;
  box-sizing: border-box;
  background: #f8fafc;
  margin-bottom: 18rpx;
}

.filter-row {
  justify-content: flex-start;
  flex-wrap: wrap;
}

.filter {
  margin: 0;
  color: #334155;
  background: #f8fafc;
}

.filter.active {
  color: #ffffff;
  background: #0f766e;
}

.add-button {
  min-width: 104rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #0f766e;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.header-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.student-button {
  min-width: 104rpx;
  height: 56rpx;
  line-height: 56rpx;
  border: 1rpx solid #0f766e;
  border-radius: 10rpx;
  color: #0f766e;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.teacher-button {
  min-width: 128rpx;
  height: 56rpx;
  line-height: 56rpx;
  border: 1rpx solid #334155;
  border-radius: 10rpx;
  color: #334155;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.empty-action {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #0f766e;
  font-weight: 700;
}

.item {
  padding: 22rpx;
}

.item-title {
  max-width: 430rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.meta {
  margin-top: 10rpx;
  color: #475569;
  font-size: 26rpx;
}
