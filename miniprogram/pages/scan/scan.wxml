<view class="page">
  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{!material}}" class="empty">材料不存在或已被删除</view>
  <block wx:else>
    <view class="section">
      <view class="row">
        <view class="title">{{material.name}}</view>
        <view class="tag {{statusClass}}">{{statusText}}</view>
      </view>
      <view class="meta">编号：{{material.material_no}}</view>
      <view class="meta">领用人所在支部：{{material.branch || '-'}}</view>
      <view class="meta">领用人：{{material.assigned_user || '-'}}</view>
      <view class="meta">签领人：{{material.signer_name || '-'}}</view>
      <view wx:if="{{material.return_requirement === 'no_return'}}" class="meta">回收要求：无需回收</view>
      <view wx:elif="{{material.return_requirement === 'need_return'}}" class="meta">回收要求：待回收</view>
    </view>

    <form wx:if="{{material.status === 'pending_receive'}}" bindsubmit="receive">
      <view class="section">
        <view class="field">
          <text class="label">领用人</text>
          <input class="input" name="person" value="{{material.assigned_user}}" placeholder="请输入领用人姓名" />
        </view>
        <view class="field">
          <text class="label">领用人所在支部</text>
          <picker mode="selector" range="{{branchOptions}}" value="{{selectedBranchIndex}}" bindchange="setReceiveBranch">
            <view class="picker">{{receiveBranch || '请选择领用人所在支部'}}</view>
          </picker>
        </view>
        <view class="field">
          <text class="label">签领人</text>
          <input class="input" name="operator" value="{{material.signer_name}}" placeholder="请输入签领人姓名" />
        </view>
        <view class="field">
          <text class="label">回收要求</text>
          <picker mode="selector" range="{{returnRequirementOptions}}" value="{{selectedReturnRequirementIndex}}" bindchange="setReturnRequirement">
            <view class="picker">{{returnRequirementOptions[selectedReturnRequirementIndex]}}</view>
          </picker>
        </view>
        <view class="field">
          <text class="label">备注</text>
          <textarea class="textarea" name="remark" placeholder="可留空"></textarea>
        </view>
      </view>
      <button class="btn" form-type="submit" loading="{{saving}}">{{returnRequirement === 'no_return' ? '确认领取并完成' : '确认领取'}}</button>
    </form>

    <form wx:elif="{{material.status === 'received'}}" bindsubmit="returnMaterial">
      <view class="section">
        <view class="field">
          <text class="label">签领人</text>
          <input class="input" name="operator" value="{{material.signer_name}}" placeholder="请输入签领人姓名" />
        </view>
        <view class="field">
          <text class="label">材料完整性</text>
          <picker mode="selector" range="{{completenessOptions}}" bindchange="setCompleteness">
            <view class="picker">{{completeness}}</view>
          </picker>
        </view>
        <view class="field">
          <text class="label">备注</text>
          <textarea class="textarea" name="remark" placeholder="例如缺页、迟交、已补齐等"></textarea>
        </view>
      </view>
      <button class="btn" form-type="submit" loading="{{saving}}">确认回收</button>
    </form>

    <view wx:else class="section">
      <view class="done-title">该材料已完成回收</view>
      <view class="muted">{{isTeacher ? '如需查看完整记录，请进入材料详情页。' : '登记已完成，无需重复提交。'}}</view>
      <button wx:if="{{isTeacher}}" class="btn secondary detail-btn" bindtap="goDetail">查看详情</button>
    </view>
  </block>
</view>
